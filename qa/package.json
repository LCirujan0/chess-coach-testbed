{
  "name": "chess-coach-qa",
  "private": true,
  "version": "0.1.0",
  "description": "Automated QA suite for Chess Coach (KnightPath). Encodes docs/qa-checklist.md as Playwright tests.",
  "type": "module",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test e-smoke",
    "test:headed": "playwright test --headed",
    "report": "playwright show-report",
    "integrity": "node scripts/integrity-check.mjs ."
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "serve": "^14.2.3"
  }
}
