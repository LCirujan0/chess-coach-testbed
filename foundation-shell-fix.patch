diff --git a/css/shell.css b/css/shell.css
new file mode 100644
index 0000000..70c4415
--- /dev/null
+++ b/css/shell.css
@@ -0,0 +1,74 @@
+/* ============================================================================
+   shell.css — THE canonical app-shell chrome shared by every training screen.
+   ----------------------------------------------------------------------------
+   Page background, .container width, header bar, hamburger (hidden on desktop),
+   the nav drawer + desktop pinned sidebar, the mobile tab bar, and the desktop
+   body offset. Values are puzzle.html's (the reference screen) so puzzle,
+   recognition and endgames render IDENTICALLY. Pages must NOT redefine this
+   chrome in their page sheet — change it here, once.
+   Load order on every training page:
+     tokens -> shell -> nav -> board -> type -> screen -> train -> [page].css
+   ============================================================================ */
+* { box-sizing: border-box; margin: 0; padding: 0; }
+
+html, body {
+  background: radial-gradient(120% 60% at 50% -10%, #FFFFFF, #EDF0F3 80%);
+  background-attachment: fixed; min-height: 100vh;
+}
+body {
+  font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
+  color: var(--ink);
+  padding: max(12px, env(safe-area-inset-top)) max(16px, env(safe-area-inset-right)) max(90px, env(safe-area-inset-bottom)) max(16px, env(safe-area-inset-left));
+  line-height: 1.5; -webkit-font-smoothing: antialiased;
+}
+.container { max-width: 560px; margin: 0 auto; }
+h1, .page-title, .nav-brand-name, .nav-drawer-title { font-family: "Plus Jakarta Sans", "Inter", sans-serif; }
+
+/* Header bar — plain (matches puzzle.html; not sticky). */
+.header-bar { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
+.page-title { font-size: 18px; font-weight: 700; letter-spacing: -.01em; }
+.hamburger-btn { background: none; border: none; padding: 4px; cursor: pointer; color: var(--ink); display: inline-flex; align-items: center; justify-content: center; border-radius: 8px; transition: background .15s; }
+.hamburger-btn:hover { background: var(--surface2); }
+
+/* Nav drawer (mobile slide-in) */
+.nav-drawer { position: fixed; top: 0; left: 0; width: 288px; max-width: 84vw; height: 100vh; background: var(--surface); border-right: 1px solid var(--line); transform: translateX(-100%); transition: transform 200ms ease; z-index: 100; padding: 20px 14px; overflow-y: auto; display: flex; flex-direction: column; gap: 4px; box-shadow: 0 20px 40px -22px rgba(20,30,55,.25); }
+.nav-drawer.open { transform: translateX(0); }
+.nav-brand { display: flex; align-items: center; gap: 10px; padding: 6px 8px 14px; margin-bottom: 6px; border-bottom: 1px solid var(--line); }
+.nav-brand-mark { width: 30px; height: 30px; border-radius: 0; background: none; box-shadow: none; object-fit: contain; flex-shrink: 0; }
+.nav-brand-name { font-weight: 700; font-size: 15px; }
+.nav-group-label { font-size: 10px; font-weight: 700; letter-spacing: .1em; text-transform: uppercase; color: var(--muted); padding: 12px 10px 4px; }
+.nav-drawer-link { display: flex; align-items: center; gap: 11px; padding: 10px 12px; border-radius: 10px; font-size: 14px; font-weight: 600; color: var(--ink); text-decoration: none; transition: background .15s ease; }
+.nav-drawer-link:hover { background: var(--surface2); }
+.nav-drawer-link.active { background: var(--accent); color: #fff; box-shadow: 0 6px 14px -8px var(--accent); }
+.nav-drawer-link .nav-icon { width: 18px; height: 18px; flex-shrink: 0; display: inline-flex; align-items: center; justify-content: center; }
+.nav-drawer-link svg.nav-icon { stroke: currentColor; fill: none; }
+.nav-drawer-link svg.nav-icon .filldot { fill: currentColor; stroke: none; }
+.nav-drawer-link.coming { color: var(--muted); }
+.nav-drawer-link.secondary { font-size: 13px; padding: 7px 12px; color: var(--muted); }
+.nav-drawer-link.secondary:hover { background: var(--surface2); }
+.nav-drawer-link.secondary.active { background: none; color: var(--accent); box-shadow: none; font-weight: 700; }
+.nav-separator { border: none; border-top: 1px solid var(--line); margin: 8px 0; }
+.version-stamp { margin-top: auto; padding: 10px 12px 4px; font-size: 10px; color: var(--muted); font-family: "Spline Sans Mono", ui-monospace, monospace; letter-spacing: .02em; border-top: 1px solid var(--line); }
+.nav-backdrop { position: fixed; inset: 0; background: rgba(15,20,30,.45); z-index: 99; opacity: 0; pointer-events: none; transition: opacity 200ms ease; }
+.nav-backdrop.open { opacity: 1; pointer-events: auto; }
+
+/* Mobile bottom tab bar */
+.tab-bar { position: fixed; bottom: 0; left: 0; right: 0; display: flex; background: var(--surface); border-top: 1px solid var(--line); z-index: 90; padding: 6px 6px max(env(safe-area-inset-bottom, 6px), 6px); box-shadow: 0 -8px 22px -16px rgba(15,20,40,.16); }
+.tab-bar a { flex: 1; display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 2px; padding: 7px 4px; border-radius: 10px; font-size: 10px; font-weight: 600; color: var(--muted); text-decoration: none; transition: color .15s ease; }
+.tab-bar a.active { color: var(--accent); }
+.tab-bar a .tab-icon { width: 22px; height: 22px; }
+.tab-bar a svg.tab-icon { stroke: currentColor; fill: none; }
+.tab-bar a svg.tab-icon .filldot { fill: currentColor; stroke: none; }
+
+.hidden { display: none !important; }
+
+/* ---- Desktop (>=880px): pinned sidebar, wide container, no tab bar, and the
+   hamburger is redundant (the sidebar is always visible) so it is hidden. ---- */
+@media (min-width: 880px) {
+  body { padding-left: 248px; padding-right: 28px; padding-bottom: 28px; font-size: 15px; }
+  .container { max-width: 1100px; margin-left: 0; margin-right: auto; }
+  .hamburger-btn { display: none; }
+  .tab-bar { display: none; }
+  .nav-backdrop { display: none !important; }
+  .nav-drawer { position: fixed !important; top: 0; left: 0; width: 224px !important; max-width: 224px !important; height: 100vh; transform: none !important; border-right: 1px solid var(--line); background: var(--surface); padding: 22px 14px 18px; z-index: 10; }
+}
