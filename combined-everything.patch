+    font-style: italic;
+  }
+  .result-repeat.hidden { display: none; }
+
+  /* ============================================================
+     §29/§30 result card — verdict banner, pips, reveal, card actions
+     ============================================================ */
+  .task-prompt { font-size: 13px; color: var(--muted); margin: -2px 0 10px; font-weight: 600; }
+  .task-prompt.hidden { display: none; }
+
+  /* One card border around the whole result block (§30.1) */
+  #result { display: flex; flex-direction: column; gap: 10px; }
+  .result-verdict { display: flex; align-items: center; gap: 11px; }
+  .verdict-icon {
+    width: 38px; height: 38px; border-radius: 50%; flex: 0 0 auto;
+    display: inline-flex; align-items: center; justify-content: center;
+    font-size: 21px; font-weight: 800; color: #fff;
+  }
+  .result.pass .verdict-icon, .result.warn .verdict-icon { background: var(--pos); }
+  .result.fail .verdict-icon { background: var(--bad); }
+  .verdict-word {
+    font-family: "Plus Jakarta Sans", "Inter", sans-serif;
+    font-size: 22px; font-weight: 800; letter-spacing: -0.01em;
+  }
+  .result.pass .verdict-word, .result.warn .verdict-word { color: var(--pos); }
+  .result.fail .verdict-word { color: var(--bad); }
+
+  /* Attempt pips — three dots; spent ones hollow (§29.2) */
+  .result-pips { margin-left: auto; display: inline-flex; gap: 6px; align-items: center; }
+  .result-pips.hidden { display: none; }
+  .result-pips .pip {
+    width: 11px; height: 11px; border-radius: 50%;
+    background: var(--bad); border: 2px solid var(--bad); box-sizing: border-box;
+  }
+  .result-pips .pip.spent { background: transparent; }
+
+  .result-subline { font-size: 13px; color: var(--muted); line-height: 1.45; }
+  .result-subline.hidden { display: none; }
+  .result-nudge { font-size: 13px; color: var(--ink); font-weight: 600; }
+  .result-nudge.hidden { display: none; }
+
+  /* One-line contrast: "You Bd6 · Best Nxd5" (§29.3) */
+  .result-contrast {
+    font-family: "Spline Sans Mono", ui-monospace, monospace; font-size: 13px;
+    color: var(--ink); background: var(--surface2); border-radius: 8px;
+    padding: 7px 11px;
+  }
+  .result-contrast.hidden { display: none; }
+  .result-contrast .c-best { color: var(--pos); font-weight: 600; }
+  .result-contrast .c-you  { color: var(--bad); font-weight: 600; }
+
+  /* Engine best line at the stop point (§30.3 + US-13). Reads as a quiet
+     labelled line, not a separate alert box — the contrast line above already
+     carries the verdict colour. */
+  .result-answer {
+    font-size: 13px; color: var(--ink);
+    background: var(--accent-soft); border-left: 3px solid var(--accent);
+    border-radius: 6px; padding: 8px 12px; line-height: 1.5;
+  }
+  .result-answer .answer-label {
+    display: inline-block; font-size: 10px; font-weight: 700; letter-spacing: .06em;
+    text-transform: uppercase; color: var(--accent); margin-right: 6px;
+  }
+  .result-answer .answer-line {
+    font-family: "Spline Sans Mono", ui-monospace, monospace; font-weight: 600;
+  }
+  .result-answer.hidden { display: none; }
+
+  /* Card action row — one dominant action per state (§29.4/§30.2) */
+  .result-actions { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 2px; }
+  .result-actions .btn { flex: 1 1 auto; min-width: 120px; }
+  .result-actions .btn.hidden { display: none; }
+  .btn.btn-review { background: var(--surface); color: var(--accent); border: 1.5px solid var(--accent); box-shadow: none; }
+  .btn.btn-review:hover { background: var(--accent-soft); }
+
+  /* Quiet "Show me the answer" escape (from the 2nd miss, §30.6 #3) */
+  .result-escape {
+    align-self: flex-start; background: none; border: none; padding: 2px 0;
+    color: var(--muted); font-size: 12px; font-family: inherit; cursor: pointer;
