+    transition: background .15s ease;
+  }
+  .nav-arrows .nav-step:hover:not(:disabled) { background: var(--surface2); }
+  .nav-arrows .nav-step:disabled { opacity: 0.3; cursor: not-allowed; }
+  .nav-label {
+    flex: 1; text-align: center;
+    /* §53 — use the type system (Inter body), readable size + weight. */
+    font-family: var(--font-body, "Inter", system-ui, sans-serif);
+    font-size: 13px; font-weight: 600; color: var(--muted);
+    letter-spacing: 0.01em;
+  }
+
+  /* ============================================================
+     Result panel = verdict card (spec §6)
+     ============================================================ */
+  @keyframes slide-down-fade {
+    from { opacity: 0; transform: translateY(-8px); }
+    to { opacity: 1; transform: translateY(0); }
+  }
+  .result {
+    padding: 14px 16px;
+    border: 1px solid var(--line);
+    border-radius: var(--r-panel);
+    background: var(--surface);
+    margin-bottom: 12px;
+    box-shadow: 0 6px 16px -10px rgba(20,30,55,.16);
+    animation: slide-down-fade 0.25s cubic-bezier(0.16, 1, 0.3, 1) forwards;
+  }
+  .result.hidden { display: none; animation: none; }
+  .result-headline {
+    display: flex; align-items: center; gap: 10px;
+    font-weight: 700; font-size: 14px;
+    margin-bottom: 4px;
+  }
+  .result-headline::before {
+    content: ""; flex-shrink: 0;
+    width: 22px; height: 22px; border-radius: 50%;
+    display: inline-block;
+    background: var(--muted);
+    background-image: var(--badge-symbol);
+    background-repeat: no-repeat; background-position: center;
+    background-size: 14px 14px;
+  }
+  .result.pass .result-headline { color: var(--pos); }
+  .result.pass .result-headline::before {
+    background-color: var(--pos);
+    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' fill='none' stroke='white' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><polyline points='3.5,8.5 6.5,11.5 12.5,5'/></svg>");
+  }
+  .result.warn .result-headline { color: var(--warn); }
+  .result.warn .result-headline::before {
+    background-color: var(--warn);
+    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' fill='white'><rect x='7' y='3' width='2' height='6' rx='1'/><circle cx='8' cy='12' r='1.2'/></svg>");
+  }
+  .result.fail .result-headline { color: var(--bad); }
+  .result.fail .result-headline::before {
+    background-color: var(--bad);
+    background-image: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' fill='none' stroke='white' stroke-width='2.5' stroke-linecap='round'><line x1='4' y1='4' x2='12' y2='12'/><line x1='12' y1='4' x2='4' y2='12'/></svg>");
+  }
+  .result.pass { background: #F1F8F4; border-color: #D4E9DC; }
+  .result.warn { background: #FBF5EA; border-color: #EBDDC2; }
+  .result.fail { background: #FBF0ED; border-color: #EDD2CB; }
+  .result-body { font-size: 13px; color: var(--ink); line-height: 1.5; }
+  /* Motif chip on the post-resolution result panel (v0.7). Hidden until the
+     reveal is earned — same gate as the engine column on the comparison
+     table. Spec-02 motif tag was previously invisible because nothing rendered
+     it outside the Filters → Theme submenu. */
+  .result-motif {
+    display: inline-flex; align-items: center; gap: 5px;
+    margin-top: 9px;
+    padding: 4px 10px;
+    background: var(--accent-soft);
+    color: var(--accent);
+    border-radius: var(--r-pill);
+    font-size: 11px; font-weight: 600;
+    letter-spacing: 0.02em;
+  }
+  .result-motif.hidden { display: none; }
+  .result-motif .label { color: var(--muted); font-weight: 500; }
+  /* Post-puzzle component picker (Deep mode only, v0.7). Capture #2 §component:
+     the student taps the training component they think this puzzle was about.
+     Stored on the just-finished attempt log entry via setAttemptComponent().
+     Drill mode hides this row per coaching-style.md "Drill skips reflection". */
+  .result-components {
+    margin-top: 12px;
+    display: flex; flex-wrap: wrap; gap: 6px;
+  }
+  .result-components.hidden { display: none; }
+  .result-components-label {
+    width: 100%;
+    font-size: 11px; font-weight: 700;
+    letter-spacing: 0.08em; text-transform: uppercase;
+    color: var(--muted);
+    margin-bottom: 4px;
+  }
+  .component-pill {
+    padding: 5px 10px;
+    background: var(--surface);
+    border: 1px solid var(--line);
+    border-radius: var(--r-pill);
+    color: var(--ink);
+    font-size: 12px; font-weight: 600;
+    cursor: pointer;
+    transition: transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1), background-color 0.15s ease, box-shadow 0.15s ease, filter 0.15s ease;
+    font-family: inherit;
+  }
+  .component-pill:hover { background: var(--surface2); }
+  .component-pill.active {
+    background: var(--accent);
+    color: #fff;
+    border-color: var(--accent);
