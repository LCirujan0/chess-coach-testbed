diff --git a/css/endgames.css b/css/endgames.css
new file mode 100644
index 0000000..b0aa792
--- /dev/null
+++ b/css/endgames.css
@@ -0,0 +1,45 @@
+/* ============================================================================
+   endgames.css — page-specific exercise widgets for endgames.html.
+   Lesson header, "show technique" panel, verdict card, lesson list, and the
+   interim coarse pawns eval bar. App-shell chrome -> shell.css; layout ->
+   screen.css; shared components (board, coach, buttons, controls) -> train.css.
+   ============================================================================ */
+.lesson-card { background: var(--surface); border: 1px solid var(--line); border-radius: var(--r-panel); padding: 14px 16px; margin-bottom: 12px; box-shadow: 0 8px 22px -14px rgba(30,40,70,.3); }
+.lesson-group-badge { display: inline-flex; align-items: center; padding: 3px 9px; background: var(--surface2); color: var(--muted); font-size: 10px; font-weight: 700; letter-spacing: .07em; text-transform: uppercase; border-radius: var(--r-pill); margin-bottom: 8px; }
+.lesson-title { font-family: "Plus Jakarta Sans", "Inter", sans-serif; font-weight: 800; font-size: 18px; line-height: 1.25; margin-bottom: 5px; }
+.lesson-stm { font-size: 13px; color: var(--muted); margin-bottom: 10px; }
+.lesson-meta-row { display: flex; align-items: center; gap: 8px; flex-wrap: wrap; }
+.technique-btn { padding: 7px 13px; background: var(--surface2); border: 1px solid var(--line); border-radius: var(--r-btn); font-size: 12px; font-weight: 600; color: var(--ink); cursor: pointer; font-family: inherit; transition: background .12s ease; }
+.technique-btn:hover { background: var(--surface3); }
+.technique-text { margin-top: 10px; padding: 10px 12px; background: var(--accent-soft); border-left: 3px solid var(--accent); border-radius: 6px; font-size: 13px; line-height: 1.5; color: var(--ink); }
+.advanced-badge { display: inline-flex; padding: 3px 8px; background: #FFF3E0; color: var(--warn); font-size: 10px; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; border-radius: var(--r-pill); }
+
+#status-text { min-height: 22px; font-size: 13px; color: var(--muted); text-align: center; margin-bottom: 8px; font-style: italic; }
+.verdict-card { background: var(--surface); border: 1px solid var(--line); border-radius: var(--r-panel); padding: 14px 16px; margin-bottom: 12px; box-shadow: 0 4px 14px -10px rgba(30,40,70,.3); }
+.verdict-headline { font-family: "Plus Jakarta Sans", "Inter", sans-serif; font-weight: 800; font-size: 16px; margin-bottom: 8px; }
+.verdict-headline.pass { color: var(--pos); }
+.verdict-headline.fail { color: var(--bad); }
+
+/* Lesson list */
+.lesson-list-card { background: var(--surface); border: 1px solid var(--line); border-radius: var(--r-panel); overflow: hidden; margin-bottom: 14px; }
+.lesson-list-header { padding: 10px 14px; font-size: 11px; font-weight: 700; letter-spacing: .08em; text-transform: uppercase; color: var(--muted); border-bottom: 1px solid var(--line); background: var(--surface2); }
+.lesson-list-group { padding: 8px 0 4px; }
+.lesson-list-group-label { padding: 4px 14px 2px; font-size: 10px; font-weight: 700; letter-spacing: .07em; text-transform: uppercase; color: var(--muted); }
+.lesson-list-item { display: flex; align-items: center; gap: 10px; padding: 9px 14px; cursor: pointer; transition: background .12s ease; border-bottom: 1px solid var(--line); }
+.lesson-list-item:last-child { border-bottom: none; }
+.lesson-list-item:hover { background: var(--surface2); }
+.lesson-list-item.active { background: var(--accent-soft); }
+.lesson-list-name { flex: 1; font-size: 13px; font-weight: 600; }
+.lesson-list-result { font-size: 11px; color: var(--muted); }
+.mastery-pips { display: flex; gap: 3px; }
+.pip { width: 7px; height: 7px; border-radius: 50%; background: var(--surface3); border: 1px solid var(--line); }
+.pip.filled { background: var(--accent); border-color: var(--accent); }
+.pip.mastered { background: var(--warn); border-color: var(--warn); }
+
+/* Interim coarse pawns eval bar */
+.eg-evalbar { display: flex; align-items: center; gap: 10px; max-width: 420px; margin: 8px auto 0; }
+.eg-evalbar.hidden { display: none; }
+.eg-evalbar-track { position: relative; flex: 1; height: 10px; border-radius: 6px; overflow: hidden; background: linear-gradient(90deg, var(--surface3) 0%, var(--surface2) 100%); }
+.eg-evalbar-fill { position: absolute; left: 50%; top: 0; bottom: 0; width: 0; background: var(--accent); transition: width .25s ease, left .25s ease, background .25s ease; }
+.eg-evalbar-fill.neg { background: var(--bad); }
+.eg-evalbar-num { min-width: 46px; text-align: right; font-family: "Spline Sans Mono", ui-monospace, monospace; font-size: 14px; font-weight: 600; color: var(--ink); }
diff --git a/css/puzzle.css b/css/puzzle.css
new file mode 100644
index 0000000..1eba0b6
--- /dev/null
+++ b/css/puzzle.css
@@ -0,0 +1,1093 @@
+/* ============================================================================
+   puzzle.css — styles for the mistake-puzzle solving screen (puzzle.html).
+   ----------------------------------------------------------------------------
+   Extracted verbatim from puzzle.html's inline <style> (was ~45KB inline).
+   Loads AFTER the shared stylesheets (tokens/nav/board/type/gate/screen/
+   session-wrap) to preserve the original cascade order. Design tokens live in
+   css/tokens.css; this file is puzzle-screen-specific presentation only.
+   Next foundation step: promote the shared bits (coach card, feedback, eval
+   bar, controls) into a common training-rail component sheet.
+   ============================================================================ */
+  /* ============================================================
+     Daylight design tokens (spec §1)
+     ============================================================ */
+
+  /* Modern browsers get the color-mix highlights for cleaner transparency. */
+  @supports (background: color-mix(in srgb, red 50%, transparent)) {
+    :root {
+      --hl-move: color-mix(in srgb, var(--accent) 26%, transparent);
+      --hl-sel:  color-mix(in srgb, var(--accent) 36%, transparent);
+    }
+  }
+
+  * { box-sizing: border-box; margin: 0; padding: 0; }
+  html, body {
+    background: radial-gradient(120% 60% at 50% -10%, #FFFFFF, #EDF0F3 80%);
+    background-attachment: fixed;
+    min-height: 100vh;
+  }
+  body {
+    font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", system-ui, sans-serif;
+    color: var(--ink);
+    padding: max(12px, env(safe-area-inset-top)) max(16px, env(safe-area-inset-right)) max(90px, env(safe-area-inset-bottom)) max(16px, env(safe-area-inset-left));
+    line-height: 1.5;
+    -webkit-font-smoothing: antialiased;
+  }
+  .container { max-width: 560px; margin: 0 auto; }
+
+  /* ============================================================
+     Typography (spec §2)
+     ============================================================ */
+  h1, .title, .page-title, .nav-drawer-title {
+    font-family: "Plus Jakarta Sans", "Inter", sans-serif;
+  }
+  /* Spline Sans Mono is data-only per redesign-spec §2 (eval numbers, FEN,
+     coords, raw counts). NOT for prose / meta / labels. .puzzle-meta moved
+     OUT — its content is "puzzle 1 of 21 · vs IanN_143 · 2026-05-29 · …"
+     which is meta prose, so it inherits Inter from body. */
+  .mono, .coord, .data {
+    font-family: "Spline Sans Mono", ui-monospace, monospace;
+  }
+
+  h1 {
+    font-size: 28px; font-weight: 700; letter-spacing: -0.02em;
+    line-height: 1.1; margin-bottom: 4px;
+  }
+  .eyebrow {
+    font-size: 11px; font-weight: 700; letter-spacing: 0.13em;
+    text-transform: uppercase; color: var(--accent); margin-bottom: 6px;
+  }
+  .meta-label {
+    font-size: 11px; font-weight: 600; letter-spacing: 0.06em;
+    text-transform: uppercase; color: var(--muted);
+  }
+
+  /* ============================================================
+     Header + page-title
+     ============================================================ */
+  .header-bar { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
+  .page-title { font-size: 18px; font-weight: 700; letter-spacing: -0.01em; }
+  .header-mode { margin-left: auto; display: flex; gap: 4px; }
+  .mode-pill {
+    padding: 6px 12px; border: 1px solid var(--line);
+    border-radius: var(--r-pill); background: var(--surface);
+    color: var(--muted); font-size: 10px; font-weight: 700;
+    letter-spacing: 0.06em; text-transform: uppercase;
+    cursor: pointer; font-family: inherit;
+    transition: transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1), background-color 0.15s ease, box-shadow 0.15s ease, filter 0.15s ease;
+  }
+  .mode-pill:hover { background: var(--surface2); }
+  .mode-pill.active {
+    background: var(--ink); color: #fff; border-color: var(--ink);
+  }
+
+  /* ============================================================
+     Sidebar / nav drawer (spec §7)
+     Mobile: slide-in drawer. Desktop: pinned sidebar.
+     ============================================================ */
+  .nav-drawer {
+    position: fixed; top: 0; left: 0;
+    width: 288px; max-width: 84vw; height: 100vh;
+    background: var(--surface); border-right: 1px solid var(--line);
+    transform: translateX(-100%);
+    transition: transform 200ms ease;
+    z-index: 100; padding: 20px 14px; overflow-y: auto;
+    display: flex; flex-direction: column; gap: 4px;
+    box-shadow: 0 20px 40px -22px rgba(20,30,55,.25);
+  }
+  .nav-drawer.open { transform: translateX(0); }
+  .nav-brand {
+    display: flex; align-items: center; gap: 10px;
+    padding: 6px 8px 14px;
+    margin-bottom: 6px;
+    border-bottom: 1px solid var(--line);
+  }
+  .nav-brand-mark {
+    width: 30px; height: 30px; border-radius: 0;
+    background: none; box-shadow: none;
+    object-fit: contain; flex-shrink: 0;
+  }
+  .nav-brand-name {
+    font-family: "Plus Jakarta Sans", sans-serif;
+    font-weight: 700; font-size: 15px;
+  }
+  .nav-group-label {
+    font-size: 10px; font-weight: 700; letter-spacing: 0.1em;
+    text-transform: uppercase; color: var(--muted);
+    padding: 12px 10px 4px;
+  }
+  .nav-drawer-link {
+    display: flex; align-items: center; gap: 11px;
+    padding: 10px 12px; border-radius: 10px;
+    font-size: 14px; font-weight: 600;
+    color: var(--ink); text-decoration: none;
+    transition: transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1), background-color 0.15s ease, box-shadow 0.15s ease, filter 0.15s ease;
+  }
+  .nav-drawer-link:hover { background: var(--surface2); }
+  .nav-drawer-link.active {
+    background: var(--accent); color: #fff;
+    box-shadow: 0 6px 14px -8px var(--accent);
+  }
+  .nav-drawer-link .nav-icon {
+    width: 18px; height: 18px; flex-shrink: 0;
+    display: inline-flex; align-items: center; justify-content: center;
+  }
+  /* SVG nav icons (spec §7) inherit colour from the link state; the active
+     pill flips text+icon to white via .nav-drawer-link.active. */
+  .nav-drawer-link svg.nav-icon { stroke: currentColor; fill: none; }
+  .nav-drawer-link svg.nav-icon .filldot { fill: currentColor; stroke: none; }
+  .tab-bar a svg.tab-icon { stroke: currentColor; fill: none; }
+  .tab-bar a svg.tab-icon .filldot { fill: currentColor; stroke: none; }
+  .nav-drawer-link.coming {
+    color: var(--muted);
+  }
+  .nav-drawer-link.coming .nav-soon {
+    margin-left: auto; font-size: 9px; font-weight: 700;
+    letter-spacing: 0.08em; text-transform: uppercase;
+    background: var(--surface2); color: var(--muted);
+    padding: 2px 7px; border-radius: 9px;
+  }
+  .nav-drawer-link.active .nav-soon { background: rgba(255,255,255,.2); color: #fff; }
+  .version-stamp {
+    margin-top: auto;
+    padding: 10px 12px 4px;
+    font-size: 10px;
+    color: var(--muted);
+    letter-spacing: 0.02em;
+    border-top: 1px solid var(--line);
+  }
+  .nav-backdrop {
+    position: fixed; inset: 0; background: rgba(15,20,30,.45);
+    z-index: 99; opacity: 0; pointer-events: none;
+    transition: opacity 200ms ease;
+  }
+  .nav-backdrop.open { opacity: 1; pointer-events: auto; }
+
+  /* Mobile tab bar (bottom) — desktop hides via media query */
+  .tab-bar {
+    position: fixed; bottom: 0; left: 0; right: 0;
+    display: flex; align-items: stretch;
+    background: var(--surface); border-top: 1px solid var(--line);
+    z-index: 90;
+    padding: 6px 6px max(env(safe-area-inset-bottom, 6px), 6px);
+    box-shadow: 0 -8px 22px -16px rgba(15,20,40,.16);
+  }
+  .tab-bar a {
+    flex: 1; display: flex; flex-direction: column;
+    align-items: center; justify-content: center; gap: 2px;
+    padding: 7px 4px; border-radius: 10px;
+    font-size: 10px; font-weight: 600;
+    color: var(--muted); text-decoration: none;
+    transition: color .15s ease;
+  }
+  .tab-bar a.active { color: var(--accent); }
+  .tab-bar a .tab-icon { width: 22px; height: 22px; }
+  .tab-bar a.coming { opacity: .55; }
+
+  /* ============================================================
+     Filters (segmented control, spec §6)
+     ============================================================ */
+  .filter-toggle {
+    display: flex; align-items: center; gap: 10px;
+    width: 100%; padding: 10px 14px;
+    background: var(--surface); border: 1px solid var(--line);
+    border-radius: var(--r-btn); color: var(--ink);
+    font-size: 13px; font-weight: 700;
+    cursor: pointer; font-family: inherit;
+    margin-bottom: 10px;
+    box-shadow: 0 2px 4px rgba(0,0,0,.03);
+    transition: transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1), background-color 0.15s ease, box-shadow 0.15s ease, filter 0.15s ease;
+  }
+  .filter-toggle:hover { background: var(--surface2); }
+  .filter-toggle .filter-badge {
+    margin-left: auto;
+    font-size: 12px; color: var(--muted); font-weight: 500;
+  }
+  .filter-toggle .filter-caret { font-size: 10px; color: var(--muted); }
+  .filter-toggle.open .filter-caret { transform: rotate(180deg); display: inline-block; }
+
+  .filter-panel {
+    padding: 14px; background: var(--surface);
+    border: 1px solid var(--line); border-radius: var(--r-panel);
+    margin-bottom: 12px;
+    box-shadow: 0 6px 16px -10px rgba(20,30,55,.16);
+  }
+  .filter-panel.hidden { display: none; }
+  .filter-group { margin-bottom: 12px; }
+  .filter-group:last-child { margin-bottom: 0; }
+  .filter-group-label {
+    font-size: 10px; font-weight: 700; letter-spacing: 0.1em;
+    text-transform: uppercase; color: var(--muted); margin-bottom: 7px;
+  }
+  .filter-tabs, .cat-tabs {
+    display: inline-flex; padding: 3px; gap: 2px;
+    background: var(--surface2); border-radius: 11px;
+    width: 100%;
+  }
+  .filter-tab, .cat-tab, .tried-tab {
+    flex: 1; border: none; background: transparent;
+    cursor: pointer; color: var(--muted);
+    font: inherit; font-size: 11px; font-weight: 600;
+    padding: 7px 10px; border-radius: 8px;
+    transition: transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1), background-color 0.15s ease, box-shadow 0.15s ease, filter 0.15s ease; white-space: nowrap;
+    text-align: center;
+  }
+  .filter-tab.active {
+    background: var(--surface); color: var(--ink);
+    box-shadow: 0 1px 3px rgba(0,0,0,.13);
+  }
+  .cat-tab.active {
+    background: var(--accent); color: #fff;
+    box-shadow: 0 2px 6px -2px var(--accent);
+  }
+  .tried-tab.active {
+    background: var(--surface); color: var(--ink);
+    box-shadow: 0 1px 3px rgba(0,0,0,.13);
+  }
+  .filter-tab.empty, .cat-tab.empty, .tried-tab.empty { opacity: 0.45; cursor: not-allowed; }
+  .filter-tab .count, .cat-tab .count, .tried-tab .count {
+    display: inline-block; background: rgba(0,0,0,.1);
+    border-radius: 8px; padding: 1px 6px; margin-left: 4px;
+    font-family: "Spline Sans Mono", monospace; font-size: 10px;
+    font-weight: 500;
+  }
+  .filter-tab.active .count, .tried-tab.active .count { background: var(--surface2); }
+
+  /* Spec 02 — Theme collapsible row + Drill this theme */
+  .theme-toggle {
+    display: flex; align-items: center; gap: 10px;
+    width: 100%; padding: 9px 12px;
+    background: var(--surface2); border: 1px solid transparent;
+    border-radius: 11px; cursor: pointer; font-family: inherit;
+    transition: transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1), background-color 0.15s ease, box-shadow 0.15s ease, filter 0.15s ease;
+  }
+  .theme-toggle:hover { background: color-mix(in srgb, var(--surface2) 80%, var(--accent) 20%); }
+  .theme-toggle .theme-current {
+    margin-left: auto; font-size: 12px; color: var(--ink);
+    font-weight: 600;
+  }
+  .theme-toggle .filter-caret {
+    font-size: 10px; color: var(--muted); transition: transform .15s ease;
+  }
+  .theme-toggle.open .filter-caret { transform: rotate(180deg); }
+  .theme-panel {
+    margin-top: 8px; padding: 10px;
+    background: var(--surface); border: 1px solid var(--line);
+    border-radius: var(--r-panel);
+  }
+  .theme-panel.hidden { display: none; }
+  .theme-pills {
+    display: flex; flex-wrap: wrap; gap: 5px;
+    max-height: 170px; overflow-y: auto;
+    margin-bottom: 10px;
+  }
+  .theme-pill {
+    padding: 5px 11px; background: var(--surface2);
+    border: 1px solid transparent; border-radius: var(--r-pill);
+    color: var(--ink); font-size: 11px; font-weight: 600;
+    cursor: pointer; font-family: inherit;
+    transition: transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1), background-color 0.15s ease, box-shadow 0.15s ease, filter 0.15s ease;
+  }
+  .theme-pill:hover { background: color-mix(in srgb, var(--surface2) 75%, var(--accent) 25%); }
+  .theme-pill.active {
+    background: var(--accent); color: #fff; border-color: var(--accent);
+    box-shadow: 0 2px 6px -2px var(--accent);
+  }
+  .theme-pill.empty { opacity: .4; cursor: not-allowed; }
+  .theme-pill .count {
+    margin-left: 4px; font-size: 10px; opacity: .8;
+    font-family: "Spline Sans Mono", monospace;
+  }
+  .drill-cta { width: 100%; margin: 0; padding: 9px 12px; font-size: 13px; }
+  .drill-cta:disabled { background: var(--surface2); color: var(--muted); box-shadow: none; }
+
+  .drill-banner {
+    display: flex; align-items: center; gap: 10px;
+    background: var(--accent-soft); border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
+    border-radius: var(--r-btn); padding: 8px 12px; margin-bottom: 10px;
+    box-shadow: 0 4px 10px -6px rgba(47,158,118,.35);
+  }
+  .drill-banner.hidden { display: none; }
+  .drill-banner .drill-label {
+    flex: 1; font-size: 13px; font-weight: 700; color: var(--accent);
+  }
+  .drill-banner .drill-end {
+    padding: 5px 10px; font-size: 11px; font-weight: 700;
+    background: transparent; border: 1px solid var(--accent); color: var(--accent);
+    border-radius: var(--r-pill); cursor: pointer; font-family: inherit;
+    transition: transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1), background-color 0.15s ease, box-shadow 0.15s ease, filter 0.15s ease;
+  }
+  .drill-banner .drill-end:hover { background: var(--accent); color: #fff; }
+  .cat-tab.active .count { background: rgba(255,255,255,.22); color: #fff; }
+
+  /* ============================================================
+     Puzzle meta + status
+     ============================================================ */
+  .puzzle-meta {
+    font-size: 12px; color: var(--muted);
+    margin-bottom: 8px;
+  }
+  .puzzle-meta.hidden { display: none; }
+  .repeat-badge {
+    display: inline-block;
+    padding: 4px 10px; background: var(--bad);
+    color: #fff; border-radius: var(--r-pill);
+    font-size: 10px; font-weight: 700;
+    letter-spacing: 0.06em; text-transform: uppercase;
+    margin-bottom: 8px;
+    box-shadow: 0 2px 6px -2px var(--bad);
+  }
+  .repeat-badge.hidden { display: none; }
+  .inline-status {
+    font-size: 12px; color: var(--muted);
+    margin-bottom: 8px;
+  }
+  .inline-status.error { color: var(--bad); }
+  .inline-status.thinking { color: var(--warn); }
+  .inline-status.hidden { display: none; }
+  /* v0.23 — user-correct-sq: subtle green tint on from/to when move was engine best */
+  .square.user-correct-sq { background-color: rgba(60, 180, 100, 0.35) !important; }
+  /* v0.23 — "Show Follow-up" button: accent tint, sits beside Restart */
+  .btn.btn-followup { background: var(--surface); color: var(--accent); border: 1.5px solid var(--accent); box-shadow: none; }
+  .btn.btn-followup:hover { background: var(--accent-soft); }
+
+  /* Thinking gate (Deep mode) styles moved to css/gate.css (v0.53b) — it is
+     now its own component, decoupled from the right column so its height can
+     never squeeze the coach. */
+
+  /* ============================================================
+     Board (spec §5) — warm wood
+     ============================================================ */
+  .board-wrap { display: flex; flex-direction: column; align-items: center; margin-bottom: 12px; }
+  .material-row { display: flex; align-items: center; gap: 0; width: 100%; max-width: 560px; min-height: 20px; margin: 0 auto; }
+  .mb-piece { width: 18px; height: 18px; display: inline-block; }
+  .mb-score { margin-left: auto; padding-left: 6px; color: var(--pos); font-family: "Spline Sans Mono", ui-monospace, monospace; font-size: 12px; font-weight: 600; }
+  /* ============================================================
+     Controls (buttons) — spec §6
+     ============================================================ */
+  .controls {
+    display: flex; flex-wrap: wrap; gap: 8px;
+    margin-bottom: 12px;
+  }
+  .btn {
+    flex: 1; min-width: 110px;
+    padding: 11px 14px;
+    font-family: inherit; font-weight: 700; font-size: 14px;
+    border: 1px solid var(--line);
+    border-radius: var(--r-btn);
+    background: var(--surface); color: var(--ink);
+    cursor: pointer;
+    transition: transform 0.15s cubic-bezier(0.34, 1.56, 0.64, 1), background-color 0.15s ease, box-shadow 0.15s ease, filter 0.15s ease;
+    box-shadow: 0 2px 4px rgba(0,0,0,.03);
+  }
+  .btn:hover { background: var(--surface2); }
