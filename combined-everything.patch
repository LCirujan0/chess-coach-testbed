+    .coach-card .acc-head { padding: 2px 0; }
+  }
+
+  /* ============================================================
+     Move-by-move comparison
+     ============================================================ */
+  .comparison {
+    padding: 14px 16px;
+    background: var(--surface);
+    border: 1px solid var(--line);
+    border-radius: var(--r-panel);
+    margin-bottom: 12px;
+    box-shadow: 0 6px 16px -10px rgba(20,30,55,.16);
+  }
+  .comparison.hidden { display: none; }
+  .comparison-title {
+    font-size: 11px; font-weight: 700; letter-spacing: 0.08em;
+    text-transform: uppercase; color: var(--muted);
+    margin-bottom: 8px;
+  }
+  .comparison table { width: 100%; border-collapse: collapse; }
+  .comparison th {
+    font-size: 10px; font-weight: 700; text-align: left;
+    padding: 5px 7px; color: var(--muted);
+    letter-spacing: 0.06em; text-transform: uppercase;
+    border-bottom: 1px solid var(--line);
