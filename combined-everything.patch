+  }
+  .result-escape:hover { color: var(--ink); }
+  .result-escape.hidden { display: none; }
+
+  .controls.hidden { display: none; }
+
+  /* ============================================================
+     §29.3 / §30.1 — iPhone progressive disclosure (accordions).
+     Comparison + coach collapse to one-tap headers on mobile; desktop
+     (>=880px) ignores .acc-collapsed and keeps them expanded.
+     ============================================================ */
+  .acc-head { display: none; }   /* shown only on mobile (below) */
+  @media (max-width: 879px) {
+    .acc-head {
+      display: flex; align-items: center; gap: 6px; cursor: pointer;
+      font-size: 13px; font-weight: 700; color: var(--ink); user-select: none;
+      list-style: none;
+    }
+    .acc-head .acc-caret { transition: transform .15s ease; color: var(--muted); }
+    .acc-collapsed .acc-caret { transform: rotate(0deg); }
+    .acc-head .acc-preview { font-weight: 400; color: var(--muted); font-size: 12px; margin-left: 4px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
+    .comparison.acc-collapsed table,
